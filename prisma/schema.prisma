generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ... the rest of the file ...
enum UserRole {
  STUDENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum FormStatus {
  SUBMITTED
  REVIEWED
  CLOSED
}

enum AvailabilityStatus {
  ONLINE
  OFFLINE
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorProfile Doctor?
  studentForms  HealthForm[]
  appointments  Appointment[]
  messagesSent  Message[] @relation("SentMessages")
  messagesRecv  Message[] @relation("ReceivedMessages")
  notifications Notification[]
}

model Doctor {
  id              String @id @default(uuid())
  userId          String @unique
  specialization  String
  availability    AvailabilityStatus @default(OFFLINE)
  approved        Boolean @default(false)

  user            User @relation(fields: [userId], references: [id])
  availabilitySlots Availability[]
  appointments    Appointment[]
  healthForms     HealthForm[]
  prescriptions   Prescription[]
}

model Availability {
  id        String   @id @default(uuid())
  doctorId  String
  day       String
  startTime String
  endTime   String

  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model Appointment {
  id        String @id @default(uuid())
  studentId String
  doctorId  String
  date      DateTime
  status    AppointmentStatus @default(PENDING)

  student User   @relation(fields: [studentId], references: [id])
  doctor  Doctor @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

model HealthForm {
  id          String @id @default(uuid())
  studentId   String
  doctorId    String?
  symptoms    String
  urgency     String
  status      FormStatus @default(SUBMITTED)

  student User   @relation(fields: [studentId], references: [id])
  doctor  Doctor? @relation(fields: [doctorId], references: [id])
  prescription Prescription?

  createdAt DateTime @default(now())
}

model Prescription {
  id          String @id @default(uuid())
  formId      String @unique
  medicines   String
  tests       String?
  notes       String?

  form HealthForm @relation(fields: [formId], references: [id])
  doctor Doctor?  @relation(fields: [doctorId], references: [id])
  doctorId String?

  createdAt DateTime @default(now())
}

model Message {
  id          String @id @default(uuid())
  senderId    String
  receiverId  String
  content     String
  read        Boolean @default(false)

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id        String @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model EmergencyContact {
  id        String @id @default(uuid())
  title     String
  phone     String
  location  String?

  createdAt DateTime @default(now())
}

model HealthResource {
  id        String @id @default(uuid())
  category  String
  title     String
  content   String

  createdAt DateTime @default(now())
}

model FAQ {
  id        String @id @default(uuid())
  question  String
  answer    String

  createdAt DateTime @default(now())
}
